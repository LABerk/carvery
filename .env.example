# Carvery local environment template
# Copy to .env and adjust as needed for your machine.
# IMPORTANT: Replace all placeholder values with your actual configuration

# Frontend (Next.js)
NEXT_PUBLIC_API_BASE_URL=http://localhost:PORT
NEXT_PUBLIC_SITE_URL=http://localhost:3000
API_BASE_URL=http://localhost:PORT

# Docker SQL Server (used by docker-compose.yml)
# Set this to a strong local password before running docker compose up -d
MSSQL_SA_PASSWORD=YourStrongPasswordHere!

# Connection String
# Use dotnet user-secrets for sensitive database credentials (recommended)
# Example:
# dotnet user-secrets set "ConnectionStrings:DefaultConnection" "Server=localhost,1433;Database=YourDbName;User Id=sa;Password=<your-password>;TrustServerCertificate=True;Encrypt=False;" --project apps/Carvery.Api
