# Carvery local environment template
# Copy to .env and adjust as needed for your machine.

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:5027
NEXT_PUBLIC_SITE_URL=http://localhost:3000
API_BASE_URL=http://localhost:5027

# Docker SQL Server (used by docker-compose.yml)
# Set this to a strong local password before running docker compose up -d
MSSQL_SA_PASSWORD=ChangeMe_LocalOnly_123!

# API secret should be set with dotnet user-secrets (recommended)
# Example:
# dotnet user-secrets set "ConnectionStrings:DefaultConnection" "Server=localhost,1433;Database=CarveryDb;User Id=sa;Password=<your-password>;TrustServerCertificate=True;Encrypt=False;"
